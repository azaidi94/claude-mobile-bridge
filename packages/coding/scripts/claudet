#!/bin/bash
#
# claudet - Start a Claude Code session
#
# The session will be auto-discovered by the Telegram bot.
#
# Usage:
#   claudet [path]
#
# Examples:
#   claudet                    # Use current dir
#   claudet ~/code/myproject   # Use specific dir
#

set -e

DIR="${1:-$PWD}"

# Resolve to absolute path
DIR="$(cd "$DIR" && pwd)"

echo "Starting Claude Code..."
echo "  Directory: $DIR"
echo ""
echo "Session will appear in Telegram bot automatically."
echo ""

# Start Claude Code
exec claude --cwd "$DIR"
