{
  "name": "claude-mobile-bridge",
  "version": "2.0.0",
  "description": "Control Claude Code sessions from your phone via Telegram",
  "type": "module",
  "license": "MIT",
  "author": "Ali Zaidi",
  "repository": {
    "type": "git",
    "url": "https://github.com/azaidi94/claude-mobile-bridge.git"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun run test:isolated",
    "test:isolated": "for f in src/__tests__/*.test.ts; do bun test \"$f\" || exit 1; done",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,json,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@grammyjs/runner": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "grammy": "^1.42.0",
    "marked": "^17.0.6",
    "openai": "^6.15.0",
    "pdfmake": "0.2",
    "zod": "^4.2.1"
  }
}
